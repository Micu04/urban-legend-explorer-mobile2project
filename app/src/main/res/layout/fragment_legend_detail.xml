<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <ImageButton
            android:id="@+id/buttonBackDetail"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginBottom="16dp"
            android:background="#111111"
            android:contentDescription="Back"
            android:src="@android:drawable/ic_media_previous"
            android:tint="#FFFFFF" />

        <ImageView
            android:id="@+id/imageLegendDetail"
            android:layout_width="match_parent"
            android:layout_height="280dp"
            android:scaleType="centerCrop"
            android:src="@android:color/darker_gray" />

        <TextView
            android:id="@+id/textDetailCategory"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="#111111"
            android:paddingStart="14dp"
            android:paddingTop="10dp"
            android:paddingEnd="14dp"
            android:paddingBottom="10dp"
            android:text="CATEGORY"
            android:textAllCaps="true"
            android:textColor="#D8D8D8"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/textDetailTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="Legend title"
            android:textColor="#FFFFFF"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/textDetailLocation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="LOCATION"
            android:textAllCaps="true"
            android:textColor="#9D9D9D"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/textDetailDescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:lineSpacingExtra="6dp"
            android:text="Description"
            android:textColor="#E0E0E0"
            android:textSize="16sp" />

        <Button
            android:id="@+id/buttonEdit"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="30dp"
            android:backgroundTint="#F2F2F2"
            android:text="EDIT LEGEND"
            android:textColor="#000000" />

        <Button
            android:id="@+id/buttonDelete"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="12dp"
            android:backgroundTint="#1A1A1A"
            android:text="DELETE LEGEND"
            android:textColor="#FFFFFF" />

    </LinearLayout>
</ScrollView>